# Template for the gateway JWT-signing Secret. The placeholders are
# filled in at apply time by generate-jwt-keys.sh (which writes the
# rendered manifest to stdout). The rendered output never lands inside
# the repo — operators pipe it directly into `kubectl apply`.
apiVersion: v1
kind: Secret
metadata:
  name: openshell-gateway-jwt
  namespace: ate-openshell-m0
type: Opaque
data:
  signing.pem: __SIGNING_PEM_B64__
  public.pem:  __PUBLIC_PEM_B64__
  kid:         __KID_B64__
